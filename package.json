{
  "name": "solid-convex-public",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev": "turbo dev",
    "dev:convex": "bun run --cwd packages/backend dev",
    "dev:todo": "bun run --cwd apps/tanstack-router-demo dev",
    "dev:tanstack": "bun run --cwd apps/tanstack-router-demo dev",
    "format": "prettier --write .",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./packages/core/src/paraglide --strategy globalVariable localStorage baseLocale --emit-ts-declarations --no-emit-git-ignore --no-emit-prettier-ignore",
    "test:unit": "bun --conditions=browser test packages/core/tests tests/unit",
    "test:convex": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@inlang/paraglide-js": "^2.20.0",
    "@playwright/test": "^1.57.0",
    "@tanstack/intent": "^0.1.1",
    "@types/node": "^24.6.2",
    "convex-test": "^0.0.53",
    "prettier": "^3.6.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.12"
}
